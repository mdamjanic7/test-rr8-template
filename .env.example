# Real-store config. Copy to `.env` and fill in. The Hydrogen CLI loads `.env`
# into the Oxygen worker environment for `pnpm dev` / `pnpm preview`.
#
# For the zero-config demo, set MOCK_SHOP=1 in `.env` (or in the worker env)
# to route Storefront API calls to the public mock.shop API and ignore the
# private token below.
#
# Point the store itself at your shop in app/lib/shop.ts; this file carries only
# server-side worker environment values.

# Set to 1 for the tokenless mock.shop demo.
# MOCK_SHOP=1

# Private Storefront API token (server-only). Required for SSR against a real store.
PRIVATE_STOREFRONT_API_TOKEN=
